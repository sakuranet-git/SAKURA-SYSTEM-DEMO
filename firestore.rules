rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // デモユーザー判定（Custom Claims: isDemo = true）
    function isDemoUser() {
      return request.auth != null && request.auth.token.isDemo == true;
    }

    // isDemo フラグ付きデータのみ書き込み許可
    function hasIsDemo() {
      return request.resource.data.isDemo == true;
    }

    // customer_records: デモユーザーのみ読み書き可（isDemoフラグ必須）
    match /customer_records/{docId} {
      allow read: if isDemoUser();
      allow write: if isDemoUser() && hasIsDemo();
    }

    // invoices: デモユーザーのみ読み書き可（isDemoフラグ必須）
    match /invoices/{docId} {
      allow read: if isDemoUser();
      allow write: if isDemoUser() && hasIsDemo();
    }

    // invitation_codes: 未認証でも読み取り可（招待コード検証用）・書き込み不可
    match /invitation_codes/{codeId} {
      allow read: if true;
      allow write: if false;
    }

    // 上記以外は全拒否
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
