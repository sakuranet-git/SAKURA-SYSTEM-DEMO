{
  "name": "sakura-system-demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preflight": "node scripts/check-no-prod-config.js && node scripts/preflight.js",
    "check:pii": "node scripts/detect-pii.js",
    "test:rules": "jest tests/firebase-rules.test.js",
    "test:network": "playwright test tests/no-prod-network.spec.js",
    "test:all": "node scripts/check-no-prod-config.js && npm run check:pii && npm run test:rules && npm run test:network",
    "emulator": "firebase emulators:start --only firestore,auth",
    "emulator:export": "firebase emulators:export emulator-data --force",
    "start:local": "npm run preflight && firebase serve --only hosting",
    "secrets:scan": "gitleaks detect --source . --config .gitleaks.toml"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.0",
    "@playwright/test": "^1.44.0",
    "jest": "^29.0.0",
    "firebase-tools": "^13.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000
  }
}
